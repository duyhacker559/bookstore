@startuml
' Render to PNG or SVG and place the output in diagrams/rendered/

title Section 18 - Roadmap Architecture Diagram
left to right direction
skinparam shadowing false
skinparam packageStyle rectangle
skinparam componentStyle rectangle
skinparam defaultFontName Arial
skinparam ArrowColor #4f5b66
skinparam packageBorderColor #2c5aa0
skinparam packageBackgroundColor #f7f9fc
skinparam componentBorderColor #2c5aa0
skinparam componentBackgroundColor #ffffff
skinparam databaseBorderColor #8f5c2c
skinparam databaseBackgroundColor #fff8ef
skinparam queueBorderColor #6a8f3a
skinparam queueBackgroundColor #f6fbef

package "Current Platform" {
  component "Django Web App\nOrchestration + UI" as django
  component "Payment Service\nFastAPI" as payment
  component "Shipping Service\nFastAPI" as shipping
  component "Notification Service\nFastAPI" as notification
  queue "RabbitMQ\nDomain Events" as rabbit
  database "Bookstore DB" as db_store
  database "Payment DB" as db_payment
  database "Shipping DB" as db_shipping
  database "Notification DB" as db_notification
}

package "Roadmap Enhancements" {
  component "API Gateway\nUnified entry + auth" as gateway
  component "Identity Layer\nJWT + RBAC" as identity
  component "Workflow Orchestrator\nOrder lifecycle policies" as orchestrator
  component "Observability Stack\nMetrics + tracing + logs" as observability
  component "CI/CD Pipeline\nValidation + deployment" as cicd
  component "Analytics / Reporting" as analytics
}

actor Customer
actor Staff

Customer --> gateway
Staff --> gateway

gateway --> django
identity --> gateway
identity --> django

django --> payment : HTTP
django --> shipping : HTTP
payment --> rabbit : publish
shipping --> rabbit : publish
rabbit --> notification : consume

django --> db_store
payment --> db_payment
shipping --> db_shipping
notification --> db_notification

orchestrator --> django : order policies
orchestrator --> payment : retry / compensate
orchestrator --> shipping : retry / compensate
observability --> django
observability --> payment
observability --> shipping
observability --> notification
cicd --> django
cicd --> payment
cicd --> shipping
cicd --> notification
analytics --> rabbit : event ingestion
analytics --> db_store : reporting reads

note bottom of gateway
Planned for Iteration 1:
authentication, authorization,
and consistent public routing.
end note

note bottom of orchestrator
Planned for Iteration 3:
event-driven order workflow
and failure recovery logic.
end note

note bottom of observability
Planned for Iteration 4:
tracing, dashboards,
and alerting.
end note

@enduml
