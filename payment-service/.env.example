"""
Environment Configuration Example
"""

# DEBUG
DEBUG=True

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000

# Database
DATABASE_URL=sqlite:///./payment_service.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/payment_db

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Authentication
PAYMENT_SERVICE_TOKEN=demo-token-123

# Monolith Communication
MONOLITH_URL=http://localhost:8000
MONOLITH_TOKEN=demo-token-123

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Logging
LOG_LEVEL=INFO
